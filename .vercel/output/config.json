{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/callback/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/me/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/content/create/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/content/upload/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/content/upload-release/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/health/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/pulls/?$",
			"dest": "_render"
		}
	]
}