---
import "../styles/global.css";
import { SITE } from "../config";

interface Props {
  title?: string;
  description?: string;
}
const { title, description } = Astro.props;
const pageTitle = title ? `${title} — ${SITE.title}` : `${SITE.title} — ${SITE.tagline}`;
const ghOwner = SITE.github.owner;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description ?? SITE.description} />
    <meta name="theme-color" content="#0a0a0c" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Kortex" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header" data-pagefind-ignore>
      <div class="wrap">
        <a class="brand" href="/">
          <img class="mark" src="/favicon.svg" alt="" />
          <span>Kortex</span>
          <span class="sep">/</span>
          <span class="sub">second brain</span>
        </a>
        <div class="header-spacer"></div>
        <a class="btn sm" href="/ask">✨ Ask AI</a>
        <nav class="header-nav" id="auth-area">
          <!-- Populated client-side via /api/auth/me to work with prerendered pages -->
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer" data-pagefind-ignore>
      <div class="wrap">
        <p>Kortex — your knowledge, versioned and yours forever.</p>
      </div>
    </footer>

    <!-- Toast container -->
    <div class="toast-container" id="toasts"></div>

    <!-- Add Content Modal -->
    <div class="modal-backdrop" id="modal-add">
      <div class="modal">
        <h2 id="add-modal-title">Add to your brain</h2>
        <form id="form-add">
          <input type="hidden" id="add-id" name="id" value="" />
          <label for="add-title">Title</label>
          <div class="input-with-mic">
            <input id="add-title" name="title" type="text" placeholder="What's on your mind?" required />
            <button type="button" class="mic-btn" data-target="add-title" title="Dictate title">🎤</button>
          </div>

          <label for="add-type">Type</label>
          <select id="add-type" name="type">
            <option value="note">Note</option>
            <option value="link">Link</option>
            <option value="idea">Idea</option>
            <option value="task">Task</option>
            <option value="routine">Routine</option>
            <option value="reference">Reference</option>
            <option value="doc">Document</option>
          </select>

          <label for="add-url">URL (optional)</label>
          <input id="add-url" name="url" type="url" placeholder="https://..." />

          <label for="add-tags">Tags (comma-separated)</label>
          <input id="add-tags" name="tags" type="text" placeholder="ai, productivity, idea" />
          <button type="button" class="btn sm" id="btn-suggest-tags" style="align-self:flex-start;margin-top:6px;">
            ✨ Suggest tags &amp; type
          </button>
          <div class="related-suggest" id="related-suggest" hidden></div>

          <label for="add-content">Content <span class="hint-inline">— type <code>[[</code> to link a note</span></label>
          <div class="content-field-wrap">
            <textarea id="add-content" name="content" placeholder="Write anything — markdown supported... Type [[ to link a note"></textarea>
            <button type="button" class="mic-btn content-mic" data-target="add-content" title="Dictate content">🎤</button>
            <div class="wikilink-suggest" id="wikilink-suggest" hidden></div>
          </div>

          <label>Attach file</label>
          <div class="file-drop" id="file-drop">
            Drop a file here or click to upload
            <input type="file" id="file-input" style="display:none" />
          </div>

          <div class="actions">
            <button type="button" class="btn" id="btn-cancel">Cancel</button>
            <button type="submit" class="btn primary" id="add-submit-btn">Publish</button>
          </div>
        </form>
      </div>
    </div>

    <!-- PR Review Modal -->
    <div class="modal-backdrop" id="modal-pulls">
      <div class="modal">
        <h2>Pending contributions</h2>
        <div id="pr-list">
          <p style="color:var(--text-tertiary);font-size:0.88rem;">Loading...</p>
        </div>
        <div class="actions">
          <button type="button" class="btn" id="btn-close-pulls">Close</button>
        </div>
      </div>
    </div>

    <!-- Owners Modal -->
    <div class="modal-backdrop" id="modal-owners">
      <div class="modal">
        <h2>Manage owners</h2>
        <p class="hint-inline" style="margin:-4px 0 14px;">
          Owners can create, edit, and delete notes directly — no pull request needed.
        </p>
        <div id="owners-list">
          <p style="color:var(--text-tertiary);font-size:0.88rem;">Loading...</p>
        </div>
        <form id="form-add-owner" style="margin-top:16px;border-top:1px solid var(--border);padding-top:16px;">
          <label for="owner-identifier">GitHub username or email</label>
          <input
            id="owner-identifier"
            name="identifier"
            type="text"
            placeholder="e.g. octocat or octocat@example.com"
            required
          />
          <p class="hint-inline" style="margin:6px 0 0;">
            We'll confirm their GitHub account and email them an invite if we can find an address.
          </p>
          <div class="actions">
            <button type="submit" class="btn primary sm" id="btn-add-owner-submit">Add owner</button>
          </div>
        </form>
        <div class="actions">
          <button type="button" class="btn" id="btn-close-owners">Close</button>
        </div>
      </div>
    </div>


    <script is:inline define:vars={{ ghOwner }}>
      // ========== Auth (client-side) ==========
      const authArea = document.getElementById('auth-area');

      async function loadAuth() {
        try {
          const res = await fetch('/api/auth/me');
          const data = await res.json();
          if (data.authenticated) {
            const isOwner = data.isOwner;
            authArea.innerHTML = [
              isOwner ? '<button class="btn sm" id="btn-pulls">PRs</button>' : '',
              isOwner ? '<button class="btn sm" id="btn-owners">👥 Owners</button>' : '',
              '<button class="btn primary" id="btn-add">+ Add</button>',
              `<img class="avatar" src="${data.avatar}" alt="${data.username}" title="${data.username}" />`,
              '<a class="btn sm" href="/api/auth/logout">Sign out</a>',
            ].join('');
            window.KORTEX_IS_OWNER = isOwner;
          } else {
            authArea.innerHTML = '<a class="btn" href="/api/auth/login">Sign in with GitHub</a>';
            window.KORTEX_IS_OWNER = false;
          }
        } catch (e) {
          authArea.innerHTML = '<a class="btn" href="/api/auth/login">Sign in</a>';
          window.KORTEX_IS_OWNER = false;
        }
        // Wire up header buttons now that they exist in the DOM
        initButtons();
        document.dispatchEvent(new CustomEvent('kortex:auth', { detail: { isOwner: window.KORTEX_IS_OWNER } }));
      }

      // ========== Toast system ==========
      function toast(message, type = 'info') {
        const el = document.createElement('div');
        el.className = `toast ${type}`;
        el.textContent = message;
        document.getElementById('toasts').appendChild(el);
        setTimeout(() => el.remove(), 4500);
      }

      // ========== Deployment status polling (persists across page navigation) ==========
      // After a direct commit (add/edit/delete), Vercel needs to build & deploy before the
      // change is actually visible. We stash the pending commit in localStorage so that even
      // if the user navigates away — back to home, into another note, or straight into
      // adding something new — before it's done, whichever page they land on resumes the
      // polling and pops the "Deployed!" toast (and refreshes) once it's really READY.
      const PENDING_DEPLOY_KEY = 'kortex:pendingDeploy';

      function savePendingDeploy(commitSha, startedAt) {
        try {
          localStorage.setItem(PENDING_DEPLOY_KEY, JSON.stringify({ commitSha, startedAt }));
        } catch {}
      }
      function clearPendingDeploy() {
        try { localStorage.removeItem(PENDING_DEPLOY_KEY); } catch {}
      }
      function loadPendingDeploy() {
        try {
          const raw = localStorage.getItem(PENDING_DEPLOY_KEY);
          return raw ? JSON.parse(raw) : null;
        } catch {
          return null;
        }
      }

      window.kortexAwaitDeploy = function (commitSha, opts = {}) {
        const { onReady, timeoutMs = 5 * 60 * 1000, intervalMs = 4000, startedAt: resumeStartedAt } = opts;
        const done = () => {
          clearPendingDeploy();
          onReady?.();
        };

        if (!commitSha) {
          done();
          return;
        }

        const startedAt = resumeStartedAt || Date.now();
        if (!resumeStartedAt) savePendingDeploy(commitSha, startedAt);
        let announcedBuilding = false;

        async function poll() {
          if (Date.now() - startedAt > timeoutMs) {
            toast('Still deploying — refresh in a bit to see your change.', 'info');
            done();
            return;
          }
          try {
            const res = await fetch(`/api/deploy-status?sha=${encodeURIComponent(commitSha)}`);
            const data = await res.json();

            if (!data.configured) {
              // No Vercel token/project set up — fall back to a short fixed delay
              setTimeout(done, 2000);
              return;
            }

            const state = data.deployment?.state;
            if (!state) {
              setTimeout(poll, intervalMs);
              return;
            }
            if (!announcedBuilding && state !== 'READY') {
              announcedBuilding = true;
              toast('Deploying your change...', 'info');
            }
            if (state === 'READY') {
              toast('Deployed! Refreshing...', 'success');
              setTimeout(done, 1500); // let the toast actually be seen before reloading
            } else if (state === 'ERROR' || state === 'CANCELED') {
              toast('Deployment failed — check your Vercel dashboard.', 'error');
              setTimeout(done, 1500);
            } else {
              setTimeout(poll, intervalMs);
            }
          } catch {
            setTimeout(poll, intervalMs);
          }
        }
        poll();
      };

      // On every page load, resume polling for any deploy that was still pending when the
      // user navigated here. Skip the auto-refresh if they're mid-way through adding a new
      // note right now, so we don't wipe out an unsaved form — they'll still see the toast.
      (function resumePendingDeploy() {
        const pending = loadPendingDeploy();
        if (!pending?.commitSha) return;
        window.kortexAwaitDeploy(pending.commitSha, {
          startedAt: pending.startedAt,
          onReady: () => {
            const addModalOpen = document.getElementById('modal-add')?.classList.contains('open');
            if (!addModalOpen) location.reload();
          },
        });
      })();

      // ========== Button wiring (called after auth loads) ==========
      function initButtons() {

      // ========== Add Modal ==========
      const modal = document.getElementById('modal-add');
      const btnAdd = document.getElementById('btn-add');
      const btnCancel = document.getElementById('btn-cancel');
      const form = document.getElementById('form-add');
      const fileDrop = document.getElementById('file-drop');
      const fileInput = document.getElementById('file-input');
      let uploadedFileUrl = null;

      function resetAddModal() {
        document.getElementById('add-id').value = '';
        document.getElementById('add-modal-title').textContent = 'Add to your brain';
        document.getElementById('add-submit-btn').textContent = 'Publish';
      }

      window.openEditModal = function (note) {
        resetAddModal();
        document.getElementById('add-id').value = note.id;
        document.getElementById('add-title').value = note.title || '';
        document.getElementById('add-type').value = note.type || 'note';
        document.getElementById('add-url').value = note.url || '';
        document.getElementById('add-tags').value = note.tags || '';
        document.getElementById('add-content').value = note.content || '';
        document.getElementById('add-modal-title').textContent = 'Edit note';
        document.getElementById('add-submit-btn').textContent = 'Save changes';
        modal.classList.add('open');
      };

      btnAdd?.addEventListener('click', () => {
        resetAddModal();
        modal.classList.add('open');
      });
      btnCancel?.addEventListener('click', () => {
        modal.classList.remove('open');
        resetAddModal();
      });
      modal?.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.remove('open');
          resetAddModal();
        }
      });

      // File upload
      fileDrop?.addEventListener('click', () => fileInput.click());
      fileInput?.addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        fileDrop.textContent = `Uploading ${file.name}...`;

        const fd = new FormData();
        fd.append('file', file);

        // Use release endpoint for files > 1MB, regular upload for smaller
        const endpoint = file.size > 1024 * 1024 ? '/api/content/upload-release' : '/api/content/upload';

        try {
          const res = await fetch(endpoint, { method: 'POST', body: fd });
          const data = await res.json();
          if (data.success) {
            uploadedFileUrl = data.url;
            fileDrop.textContent = `Attached: ${file.name}`;
            toast('File uploaded successfully', 'success');
          } else {
            throw new Error(data.error);
          }
        } catch (err) {
          fileDrop.textContent = 'Upload failed — click to retry';
          toast(err.message || 'Upload failed', 'error');
        }
      });

      // Auto link preview: when a URL is pasted/entered, fetch title + description
      const urlInput = document.getElementById('add-url');
      const titleInput = document.getElementById('add-title');
      const contentInput = document.getElementById('add-content');
      const typeSelect = document.getElementById('add-type');
      let lastPreviewedUrl = null;

      urlInput?.addEventListener('blur', async () => {
        const val = urlInput.value.trim();
        if (!val || val === lastPreviewedUrl) return;
        try {
          new URL(val);
        } catch {
          return;
        }
        lastPreviewedUrl = val;

        try {
          const res = await fetch(`/api/content/preview?url=${encodeURIComponent(val)}`);
          const data = await res.json();
          if (data.error) throw new Error(data.error);
          if (!titleInput.value.trim() && data.title) titleInput.value = data.title;
          if (!contentInput.value.trim() && data.description) contentInput.value = data.description;
          if (typeSelect.value === 'note') typeSelect.value = 'link';
          toast('Link preview loaded', 'success');
        } catch (err) {
          // Non-fatal — user can still fill in the form manually
        }
      });

      // ========== Wiki-link autocomplete: type [[ in content to fuzzy-search & click a note title ==========
      const wikiSuggest = document.getElementById('wikilink-suggest');
      let allNoteTitles = [];
      let titlesLoaded = false;
      let wikiActiveIndex = -1;
      let wikiMatchStart = -1;

      async function ensureTitlesLoaded() {
        if (titlesLoaded) return;
        titlesLoaded = true;
        try {
          const res = await fetch('/api/content/titles');
          allNoteTitles = await res.json();
        } catch {
          allNoteTitles = [];
        }
      }

      function fuzzyScore(query, text) {
        query = query.toLowerCase();
        text = text.toLowerCase();
        if (!query) return 1;
        if (text.includes(query)) return 100 - text.indexOf(query);
        let qi = 0;
        for (let i = 0; i < text.length && qi < query.length; i++) {
          if (text[i] === query[qi]) qi++;
        }
        return qi === query.length ? 10 : -1;
      }

      function renderWikiSuggest(query) {
        const matches = allNoteTitles
          .map((n) => ({ ...n, score: fuzzyScore(query, n.title) }))
          .filter((n) => n.score > 0)
          .sort((a, b) => b.score - a.score)
          .slice(0, 6);

        if (!matches.length) {
          wikiSuggest.hidden = true;
          return;
        }

        wikiActiveIndex = 0;
        wikiSuggest.innerHTML = matches
          .map(
            (n, i) =>
              `<div class="wikilink-suggest-item${i === 0 ? ' active' : ''}" data-title="${n.title.replace(/"/g, '&quot;')}">${n.title}</div>`,
          )
          .join('');
        wikiSuggest.hidden = false;
      }

      function insertWikiLink(title) {
        const val = contentInput.value;
        const caret = wikiMatchStart >= 0 ? contentInput.selectionStart : val.length;
        const start = wikiMatchStart >= 0 ? wikiMatchStart : val.length;
        const before = val.slice(0, start);
        const after = val.slice(caret);
        const sep = wikiMatchStart >= 0 || !before || before.endsWith('\n') || before.endsWith(' ') ? '' : ' ';
        const insertText = `${sep}[[${title}]]`;
        contentInput.value = before + insertText + after;
        const newCaret = before.length + insertText.length;
        contentInput.focus();
        contentInput.setSelectionRange(newCaret, newCaret);
        wikiSuggest.hidden = true;
        wikiMatchStart = -1;
      }

      contentInput?.addEventListener('input', async () => {
        const caret = contentInput.selectionStart;
        const before = contentInput.value.slice(0, caret);
        const match = before.match(/\[\[([^[\]]*)$/);
        if (!match) {
          wikiSuggest.hidden = true;
          wikiMatchStart = -1;
          return;
        }
        wikiMatchStart = caret - match[0].length;
        await ensureTitlesLoaded();
        renderWikiSuggest(match[1]);
      });

      contentInput?.addEventListener('keydown', (e) => {
        if (wikiSuggest.hidden) return;
        const items = [...wikiSuggest.querySelectorAll('.wikilink-suggest-item')];
        if (!items.length) return;
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          wikiActiveIndex = (wikiActiveIndex + 1) % items.length;
          items.forEach((it, i) => it.classList.toggle('active', i === wikiActiveIndex));
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          wikiActiveIndex = (wikiActiveIndex - 1 + items.length) % items.length;
          items.forEach((it, i) => it.classList.toggle('active', i === wikiActiveIndex));
        } else if (e.key === 'Enter') {
          e.preventDefault();
          insertWikiLink(items[wikiActiveIndex].dataset.title);
        } else if (e.key === 'Escape') {
          wikiSuggest.hidden = true;
        }
      });

      wikiSuggest?.addEventListener('mousedown', (e) => {
        const item = e.target.closest('.wikilink-suggest-item');
        if (item) {
          e.preventDefault();
          insertWikiLink(item.dataset.title);
        }
      });

      contentInput?.addEventListener('blur', () => {
        setTimeout(() => {
          wikiSuggest.hidden = true;
        }, 150);
      });

      // ========== Voice dictation (Web Speech API, free & offline-capable) ==========
      const SpeechRec = window.SpeechRecognition || window.webkitSpeechRecognition;
      document.querySelectorAll('.mic-btn').forEach((btn) => {
        if (!SpeechRec) {
          btn.style.display = 'none';
          return;
        }
        btn.addEventListener('click', () => {
          const target = document.getElementById(btn.dataset.target);
          if (!target) return;
          const rec = new SpeechRec();
          rec.lang = 'en-US';
          rec.interimResults = false;
          rec.onresult = (e) => {
            const text = e.results[0][0].transcript;
            target.value = (target.value ? target.value.trim() + ' ' : '') + text;
            target.dispatchEvent(new Event('input', { bubbles: true }));
          };
          rec.onerror = () => {
            btn.classList.remove('recording');
            toast('Voice input failed or was denied', 'error');
          };
          rec.onend = () => btn.classList.remove('recording');
          btn.classList.add('recording');
          rec.start();
        });
      });

      // AI-suggested tags, type & related notes (via Groq, optional)
      const btnSuggest = document.getElementById('btn-suggest-tags');
      const tagsInput = document.getElementById('add-tags');
      const relatedBox = document.getElementById('related-suggest');

      relatedBox?.addEventListener('click', (e) => {
        const chip = e.target.closest('.chip');
        if (chip) insertWikiLink(chip.dataset.title);
      });

      btnSuggest?.addEventListener('click', async () => {
        const title = titleInput.value.trim();
        const content = contentInput.value.trim();
        if (!title && !content) {
          toast('Write a title or some content first', 'info');
          return;
        }
        btnSuggest.disabled = true;
        btnSuggest.textContent = 'Thinking...';
        relatedBox.hidden = true;
        try {
          await ensureTitlesLoaded();
          const res = await fetch('/api/content/suggest-tags', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title, content, existingTitles: allNoteTitles.map((n) => n.title) }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Suggestion failed');
          if (data.tags?.length) tagsInput.value = data.tags.join(', ');
          if (data.type) typeSelect.value = data.type;
          if (data.related?.length) {
            relatedBox.innerHTML =
              'Related — click to link: ' +
              data.related
                .map((t) => `<button type="button" class="chip" data-title="${t.replace(/"/g, '&quot;')}">${t}</button>`)
                .join('');
            relatedBox.hidden = false;
          }
          toast('Suggestions applied', 'success');
        } catch (err) {
          toast(err.message || 'Could not suggest tags', 'error');
        } finally {
          btnSuggest.disabled = false;
          btnSuggest.textContent = '✨ Suggest tags & type';
        }
      });

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(form));
        const editId = data.id;
        if (uploadedFileUrl) {
          data.content = (data.content || '') + `\n\n[Attached file](${uploadedFileUrl})`;
        }

        const endpoint = editId ? `/api/content/${editId}` : '/api/content/create';
        const method = editId ? 'PUT' : 'POST';

        try {
          toast(editId ? 'Saving changes...' : 'Saving...', 'info');
          const res = await fetch(endpoint, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          const result = await res.json();

          if (result.success) {
            modal.classList.remove('open');
            form.reset();
            resetAddModal();
            uploadedFileUrl = null;
            fileDrop.textContent = 'Drop a file here or click to upload';
            relatedBox.hidden = true;
            relatedBox.innerHTML = '';

            if (editId) {
              toast('Note updated! Deploying...', 'info');
              window.kortexAwaitDeploy(result.commitSha, { onReady: () => location.reload() });
            } else if (result.action === 'committed') {
              toast('Published! Deploying...', 'info');
              window.kortexAwaitDeploy(result.commitSha, { onReady: () => location.reload() });
            } else if (result.action === 'pr_created') {
              toast('Suggestion submitted as a Pull Request!', 'success');
              setTimeout(() => location.reload(), 1500);
            }
          } else {
            throw new Error(result.error);
          }
        } catch (err) {
          toast(err.message || 'Something went wrong', 'error');
        }
      });

      // ========== PR Review Modal ==========
      const modalPulls = document.getElementById('modal-pulls');
      const btnPulls = document.getElementById('btn-pulls');
      const btnClosePulls = document.getElementById('btn-close-pulls');
      const prList = document.getElementById('pr-list');

      btnPulls?.addEventListener('click', async () => {
        modalPulls.classList.add('open');
        prList.innerHTML = '<p style="color:var(--text-tertiary);font-size:0.88rem;">Loading...</p>';

        try {
          const res = await fetch('/api/pulls');
          const pulls = await res.json();

          if (!pulls.length) {
            prList.innerHTML = '<p style="color:var(--text-tertiary);font-size:0.88rem;">No pending contributions.</p>';
            return;
          }

          prList.innerHTML = pulls.map(pr => `
            <div class="pr-item">
              <img class="avatar" src="${pr.avatar}" alt="${pr.user}" />
              <div class="pr-info">
                <div class="pr-title">${pr.title}</div>
                <div class="pr-meta">by @${pr.user} · ${new Date(pr.created).toLocaleDateString()}</div>
              </div>
              <div class="pr-actions">
                <button class="btn sm primary" onclick="handlePR(${pr.number}, 'merge')">Merge</button>
                <button class="btn sm" onclick="handlePR(${pr.number}, 'close')">Close</button>
              </div>
            </div>
          `).join('');
        } catch (err) {
          prList.innerHTML = '<p style="color:var(--text-tertiary);">Failed to load PRs</p>';
        }
      });

      btnClosePulls?.addEventListener('click', () => modalPulls.classList.remove('open'));
      modalPulls?.addEventListener('click', (e) => {
        if (e.target === modalPulls) modalPulls.classList.remove('open');
      });

      window.handlePR = async function(number, action) {
        try {
          const res = await fetch('/api/pulls', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ number, action }),
          });
          const result = await res.json();
          if (result.success) {
            toast(`PR ${action === 'merge' ? 'merged' : 'closed'} successfully!`, 'success');
            btnPulls.click(); // Refresh list
          } else {
            throw new Error(result.error);
          }
        } catch (err) {
          toast(err.message || 'Action failed', 'error');
        }
      };

      // ========== Owners Modal ==========
      const modalOwners = document.getElementById('modal-owners');
      const btnOwners = document.getElementById('btn-owners');
      const btnCloseOwners = document.getElementById('btn-close-owners');
      const ownersList = document.getElementById('owners-list');
      const formAddOwner = document.getElementById('form-add-owner');

      function renderOwnersList(owners) {
        if (!owners.length) {
          ownersList.innerHTML = '<p style="color:var(--text-tertiary);font-size:0.88rem;">No owners yet.</p>';
          return;
        }
        ownersList.innerHTML = owners
          .map(
            (o) => `
          <div class="owner-item">
            <div class="owner-info">
              <strong>@${o.username}</strong>
              ${o.email ? `<span class="owner-email">${o.email}</span>` : ''}
              ${o.isStatic ? '<span class="tag">env</span>' : ''}
            </div>
            ${o.isStatic ? '' : `<button type="button" class="btn sm danger" data-remove="${o.username}">Remove</button>`}
          </div>`,
          )
          .join('');
      }

      async function loadOwnersList() {
        ownersList.innerHTML = '<p style="color:var(--text-tertiary);font-size:0.88rem;">Loading...</p>';
        try {
          const res = await fetch('/api/owners');
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Failed to load owners');
          renderOwnersList(data.owners);
        } catch (err) {
          ownersList.innerHTML = `<p style="color:var(--text-tertiary);">${err.message}</p>`;
        }
      }

      btnOwners?.addEventListener('click', () => {
        modalOwners.classList.add('open');
        loadOwnersList();
      });
      btnCloseOwners?.addEventListener('click', () => modalOwners.classList.remove('open'));
      modalOwners?.addEventListener('click', (e) => {
        if (e.target === modalOwners) modalOwners.classList.remove('open');
      });

      ownersList?.addEventListener('click', async (e) => {
        const btn = e.target.closest('[data-remove]');
        if (!btn) return;
        const username = btn.dataset.remove;
        if (!confirm(`Remove @${username} as an owner?`)) return;
        try {
          const res = await fetch(`/api/owners/${username}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
          });
          const text = await res.text();
          let result = {};
          try {
            result = text ? JSON.parse(text) : {};
          } catch {
            /* non-JSON response */
          }
          if (!res.ok) throw new Error(result.error || `Remove failed (${res.status})`);
          toast(`Removed @${username}`, 'success');
          loadOwnersList();
        } catch (err) {
          toast(err.message || 'Remove failed', 'error');
        }
      });

      formAddOwner?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const identifier = document.getElementById('owner-identifier').value.trim();
        if (!identifier) return;
        const submitBtn = document.getElementById('btn-add-owner-submit');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Adding...';
        try {
          const res = await fetch('/api/owners', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ identifier }),
          });
          const result = await res.json();
          if (!res.ok) throw new Error(result.error || 'Failed to add owner');
          formAddOwner.reset();
          if (result.emailSent) {
            toast(`@${result.username} added — invite email sent!`, 'success');
          } else if (result.email) {
            toast(`@${result.username} added — email not sent (${result.emailError || 'email not configured'})`, 'info');
          } else {
            toast(`@${result.username} added — no public email found to notify them`, 'info');
          }
          loadOwnersList();
        } catch (err) {
          toast(err.message || 'Failed to add owner', 'error');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Add owner';
        }
      });

      } // end initButtons

      // ========== Cmd/Ctrl+K quick-add ==========
      document.addEventListener('keydown', (e) => {
        const isTypingTarget = ['INPUT', 'TEXTAREA', 'SELECT'].includes(document.activeElement?.tagName);
        if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
          e.preventDefault();
          const addModal = document.getElementById('modal-add');
          if (addModal) {
            addModal.classList.add('open');
            document.getElementById('add-title')?.focus();
          } else {
            toast('Sign in to add content', 'info');
          }
        } else if (e.key === 'Escape' && !isTypingTarget) {
          document.querySelectorAll('.modal-backdrop.open').forEach((m) => m.classList.remove('open'));
        }
      });

      // ========== Scroll animations ==========
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('animate-in');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08 }
      );
      document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));

      // Boot
      loadAuth();

      // ========== PWA service worker ==========
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
  </body>
</html>
