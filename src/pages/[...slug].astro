---
export const prerender = true;

import { getCollection, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { WIKILINK_RE, wikilinkSlug, resolveWikilink } from "../lib/wikilinks.mjs";

export async function getStaticPaths() {
  const notes = await getCollection("notes", ({ data }) => data.public !== false);
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note, allNotes: notes },
  }));
}

const { note, allNotes } = Astro.props;
const { Content } = await render(note);
const date = note.data.updated ?? note.data.created;
const rawContent = (note.body || "").replace(/^---[\s\S]*?---\s*/, "");
const editableNote = {
  id: note.id,
  title: note.data.title,
  type: note.data.type,
  tags: note.data.tags.join(", "),
  url: note.data.url || "",
  content: rawContent,
};

// ---------- Backlinks: which other notes reference this one via [[Title]] ----------
const backlinkCandidates = allNotes.map((n) => ({ id: n.id, slug: wikilinkSlug(n.data.title) }));
const backlinks = allNotes.filter((n) => {
  if (n.id === note.id) return false;
  const matches = [...(n.body || "").matchAll(WIKILINK_RE)];
  return matches.some((m) => resolveWikilink(m[1].trim(), backlinkCandidates)?.id === note.id);
});
---

<Layout title={note.data.title}>
  <div class="wrap">
    <article class="article">
      <div class="article-topbar">
        <a class="back" href="/">&larr; Back</a>
        <div class="note-actions" id="note-actions" hidden>
          <button type="button" class="btn sm" id="btn-edit-note">✏️ Edit</button>
          <button type="button" class="btn sm danger" id="btn-delete-note">🗑 Delete</button>
        </div>
      </div>
      <h1 class="animate-in">{note.data.title}</h1>
      <div class="meta animate-in delay-1">
        <span class="type">{note.data.type}</span>
        {date && <span class="date">{date.toISOString().slice(0, 10)}</span>}
        {note.data.tags.map((t) => <span class="tag">{t}</span>)}
      </div>

      {note.data.url && (
        <a class="linkout animate-in delay-2" href={note.data.url} target="_blank" rel="noopener">
          Open link &nearr;
        </a>
      )}
      {note.data.attachment && (
        <a class="linkout animate-in delay-2" href={note.data.attachment} target="_blank" rel="noopener">
          Open attachment &nearr;
        </a>
      )}

      <div class="prose animate-in delay-2">
        <Content />
      </div>

      {backlinks.length > 0 && (
        <div class="backlinks animate-in delay-3">
          <h2>Linked mentions</h2>
          <ul>
            {backlinks.map((b) => (
              <li><a href={`/${b.id}/`}>{b.data.title}</a></li>
            ))}
          </ul>
        </div>
      )}
    </article>
  </div>
</Layout>

<script is:inline define:vars={{ editableNote }}>
  function showNoteActionsIfOwner(isOwner) {
    const actions = document.getElementById('note-actions');
    if (actions && isOwner) actions.hidden = false;
  }

  if (typeof window.KORTEX_IS_OWNER !== 'undefined') showNoteActionsIfOwner(window.KORTEX_IS_OWNER);
  document.addEventListener('kortex:auth', (e) => showNoteActionsIfOwner(e.detail.isOwner));

  document.getElementById('btn-edit-note')?.addEventListener('click', () => {
    window.openEditModal?.(editableNote);
  });

  document.getElementById('btn-delete-note')?.addEventListener('click', async () => {
    if (!confirm(`Delete "${editableNote.title}"? This can't be undone.`)) return;
    try {
      const res = await fetch(`/api/content/${editableNote.id}`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
      });
      const text = await res.text();
      let result = {};
      try { result = text ? JSON.parse(text) : {}; } catch { /* non-JSON response */ }
      if (!res.ok) throw new Error(result.error || `Delete failed (${res.status})`);
      window.location.href = '/';
    } catch (err) {
      alert(err.message || 'Delete failed');
    }
  });
</script>

