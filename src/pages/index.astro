---
export const prerender = true;

import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config";

const all = await getCollection("notes", ({ data }) => data.public !== false);

const entries = all.sort((a, b) => {
  const pin = (b.data.pinned ? 1 : 0) - (a.data.pinned ? 1 : 0);
  if (pin !== 0) return pin;
  const ad = (a.data.updated ?? a.data.created ?? new Date(0)).getTime();
  const bd = (b.data.updated ?? b.data.created ?? new Date(0)).getTime();
  return bd - ad;
});

const types = [...new Set(entries.map((e) => e.data.type))].sort();

function excerpt(body: string | undefined) {
  if (!body) return "";
  return body
    .replace(/^---[\s\S]*?---/, "")
    .replace(/[#*_`>\[\]!]/g, "")
    .replace(/\(https?:[^)]*\)/g, "")
    .replace(/\s+/g, " ")
    .trim()
    .slice(0, 180);
}
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <div class="wrap">
      <span class="label animate-in">Your knowledge hub</span>
      <h1 class="animate-in delay-1">Everything you know,<br/>in one place.</h1>
      <p class="animate-in delay-2">{SITE.description}</p>
      <div class="hero-actions animate-in delay-3">
        <a class="btn" href={`https://github.com/${SITE.github.owner}/${SITE.github.repo}`} target="_blank" rel="noopener">
          View source
        </a>
      </div>
    </div>
  </section>

  <div class="wrap">
    <!-- Stats -->
    <div class="stats animate-in delay-2" data-animate>
      <div class="stat"><b>{entries.length}</b><span>total</span></div>
      {types.map((t) => (
        <div class="stat">
          <b>{entries.filter((e) => e.data.type === t).length}</b>
          <span>{t}</span>
        </div>
      ))}
    </div>

    <!-- Controls -->
    <div class="controls">
      <div class="search-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          id="search"
          class="search"
          type="search"
          placeholder="Search everything..."
          autocomplete="off"
        />
      </div>
      <div class="chips" id="type-chips">
        <button class="chip" data-type="all" aria-pressed="true">All</button>
        {types.map((t) => (
          <button class="chip" data-type={t} aria-pressed="false">{t}</button>
        ))}
      </div>
    </div>

    <!-- Grid -->
    <div class="grid" id="grid">
      {entries.map((e, i) => {
        const searchText = (
          e.data.title + " " + e.data.tags.join(" ") + " " + e.data.type + " " + excerpt(e.body)
        ).toLowerCase();
        return (
          <article
            class={`card`}
            data-type={e.data.type}
            data-search={searchText}
            data-animate
            style={`animation-delay: ${Math.min(i * 0.05, 0.4)}s`}
          >
            {e.data.pinned && <span class="pin" />}
            <div class="meta">
              <span class="type">{e.data.type}</span>
              {(e.data.updated || e.data.created) && (
                <span class="date">
                  {(e.data.updated ?? e.data.created)!.toISOString().slice(0, 10)}
                </span>
              )}
            </div>
            <h3>
              {e.data.url ? (
                <a href={e.data.url} target="_blank" rel="noopener">{e.data.title}</a>
              ) : (
                <a href={`/${e.id}/`}>{e.data.title}</a>
              )}
            </h3>
            {excerpt(e.body) && <p class="excerpt">{excerpt(e.body)}</p>}
            {e.data.tags.length > 0 && (
              <div class="tags">
                {e.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </article>
        );
      })}
    </div>
    <p class="empty" id="empty" hidden>No results found.</p>
  </div>
</Layout>

<script is:inline>
  const search = document.getElementById("search");
  const grid = document.getElementById("grid");
  const empty = document.getElementById("empty");
  const chips = document.getElementById("type-chips");
  const cards = Array.from(grid.querySelectorAll(".card"));
  let activeType = "all";
  let query = "";

  function apply() {
    let shown = 0;
    for (const card of cards) {
      const matchType = activeType === "all" || card.dataset.type === activeType;
      const matchText = !query || card.dataset.search.includes(query);
      const show = matchType && matchText;
      card.hidden = !show;
      if (show) shown++;
    }
    empty.hidden = shown !== 0;
  }

  search.addEventListener("input", (e) => {
    query = e.target.value.trim().toLowerCase();
    apply();
  });

  chips.addEventListener("click", (e) => {
    const btn = e.target.closest(".chip");
    if (!btn) return;
    activeType = btn.dataset.type;
    chips.querySelectorAll(".chip").forEach((c) =>
      c.setAttribute("aria-pressed", String(c === btn))
    );
    apply();
  });
</script>
