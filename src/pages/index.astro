---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { SITE, isGithubConfigured } from "../config";

const base = import.meta.env.BASE_URL;

const all = await getCollection("notes", ({ data }) => data.public !== false);

const entries = all.sort((a, b) => {
  const pin = (b.data.pinned ? 1 : 0) - (a.data.pinned ? 1 : 0);
  if (pin !== 0) return pin;
  const ad = (a.data.updated ?? a.data.created ?? new Date(0)).getTime();
  const bd = (b.data.updated ?? b.data.created ?? new Date(0)).getTime();
  return bd - ad;
});

const types = [...new Set(entries.map((e) => e.data.type))].sort();

function href(id: string) {
  return `${base.replace(/\/$/, "")}/${id}/`;
}

function excerpt(body: string | undefined) {
  if (!body) return "";
  return body
    .replace(/^---[\s\S]*?---/, "")
    .replace(/[#*_`>\[\]!]/g, "")
    .replace(/\(https?:[^)]*\)/g, "")
    .replace(/\s+/g, " ")
    .trim()
    .slice(0, 200);
}

const configured = isGithubConfigured();
---

<Layout>
  <section class="hero">
    <span class="label">Knowledge hub</span>
    <h1>Everything, in one place.</h1>
    <p>{SITE.description}</p>
  </section>

  <div class="stats">
    <div class="stat"><b>{entries.length}</b><span>total</span></div>
    {
      types.map((t) => (
        <div class="stat">
          <b>{entries.filter((e) => e.data.type === t).length}</b>
          <span>{t}</span>
        </div>
      ))
    }
  </div>

  <div class="controls">
    <input
      id="search"
      class="search"
      type="search"
      placeholder="Search everything — title, tags, content…"
      autocomplete="off"
    />
    <div class="chips" id="type-chips">
      <button class="chip" data-type="all" aria-pressed="true">All</button>
      {
        types.map((t) => (
          <button class="chip" data-type={t} aria-pressed="false">
            {t}
          </button>
        ))
      }
    </div>
  </div>

  <div class="grid" id="grid">
    {
      entries.map((e) => {
        const searchText = (
          e.data.title +
          " " +
          e.data.tags.join(" ") +
          " " +
          e.data.type +
          " " +
          excerpt(e.body)
        ).toLowerCase();
        return (
          <article
            class="card"
            data-type={e.data.type}
            data-search={searchText}
          >
            <div class="meta">
              <span class="type">{e.data.type}</span>
              {e.data.updated || e.data.created ? (
                <span class="date">
                  {(e.data.updated ?? e.data.created)!
                    .toISOString()
                    .slice(0, 10)}
                </span>
              ) : null}
            </div>
            {e.data.pinned ? <span class="pin" title="Pinned" /> : null}
            <h3>
              {e.data.url ? (
                <a href={e.data.url} target="_blank" rel="noopener">
                  {e.data.title} ↗
                </a>
              ) : (
                <a href={href(e.id)}>{e.data.title}</a>
              )}
            </h3>
            {excerpt(e.body) ? <p class="excerpt">{excerpt(e.body)}</p> : null}
            {e.data.tags.length ? (
              <div class="tags">
                {e.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            ) : null}
          </article>
        );
      })
    }
  </div>
  <p class="empty" id="empty" hidden>No matches. Try another search.</p>

  {
    !configured ? (
      <section id="add" class="article" style="margin-top:48px">
        <h2>How to add things</h2>
        <p>
          Once you push this to GitHub and set your username in{" "}
          <code>src/config.ts</code>, the <b>+ Add</b> button will open a
          one-click "new note" editor. For now:
        </p>
        <ol>
          <li>
            Create a Markdown file in <code>content/notes/</code> — e.g.{" "}
            <code>my-idea.md</code>.
          </li>
          <li>
            Add a small header and your content:
            <pre><code>---
title: My idea
type: idea
tags: [side-project]
---

Write anything here. Links, lists, images, checklists…</code></pre>
          </li>
          <li>Save. It appears here instantly.</li>
        </ol>
      </section>
    ) : null
  }
</Layout>

<script is:inline>
  const search = document.getElementById("search");
  const grid = document.getElementById("grid");
  const empty = document.getElementById("empty");
  const chips = document.getElementById("type-chips");
  const cards = Array.from(grid.querySelectorAll(".card"));
  let activeType = "all";
  let query = "";

  function apply() {
    let shown = 0;
    for (const card of cards) {
      const matchType =
        activeType === "all" || card.dataset.type === activeType;
      const matchText = !query || card.dataset.search.includes(query);
      const show = matchType && matchText;
      card.hidden = !show;
      if (show) shown++;
    }
    empty.hidden = shown !== 0;
  }

  search.addEventListener("input", (e) => {
    query = e.target.value.trim().toLowerCase();
    apply();
  });

  chips.addEventListener("click", (e) => {
    const btn = e.target.closest(".chip");
    if (!btn) return;
    activeType = btn.dataset.type;
    chips
      .querySelectorAll(".chip")
      .forEach((c) => c.setAttribute("aria-pressed", String(c === btn)));
    apply();
  });
</script>
