---
export const prerender = true;

import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config";

const all = await getCollection("notes", ({ data }) => data.public !== false);

const entries = all.sort((a, b) => {
  const pin = (b.data.pinned ? 1 : 0) - (a.data.pinned ? 1 : 0);
  if (pin !== 0) return pin;
  const ad = (a.data.updated ?? a.data.created ?? new Date(0)).getTime();
  const bd = (b.data.updated ?? b.data.created ?? new Date(0)).getTime();
  return bd - ad;
});

const types = [...new Set(entries.map((e) => e.data.type))].sort();

function excerpt(body: string | undefined) {
  if (!body) return "";
  return body
    .replace(/^---[\s\S]*?---/, "")
    .replace(/[#*_`>\[\]!]/g, "")
    .replace(/\(https?:[^)]*\)/g, "")
    .replace(/\s+/g, " ")
    .trim()
    .slice(0, 180);
}
---

<Layout>
  <!-- Hero -->
  <section class="hero" id="hero" data-pagefind-ignore>
    <div class="hero-orbs" aria-hidden="true">
      <span class="orb orb-1"></span>
      <span class="orb orb-2"></span>
      <span class="orb orb-3"></span>
    </div>
    <div class="hero-spotlight" id="hero-spotlight" aria-hidden="true"></div>
    <div class="wrap">
      <span class="label animate-in">Your knowledge hub</span>
      <h1 class="animate-in delay-1">Everything you know,<br/>in one place.</h1>
      <p class="animate-in delay-2">{SITE.description}</p>
      <div class="hero-actions animate-in delay-3">
        <a class="btn" href={`https://github.com/${SITE.github.owner}/${SITE.github.repo}`} target="_blank" rel="noopener">
          View source
        </a>
        <a class="btn" href="/graph">Graph view</a>
        <a class="btn" href="/today">Today</a>
        <span class="kbd-hint"><kbd>⌘</kbd>/<kbd>Ctrl</kbd> + <kbd>K</kbd> to quick-add</span>
      </div>
    </div>
  </section>

  <div class="wrap">
    <!-- Stats -->
    <div class="stats animate-in delay-2" data-animate>
      <div class="stat"><b>{entries.length}</b><span>total</span></div>
      {types.map((t) => (
        <div class="stat">
          <b>{entries.filter((e) => e.data.type === t).length}</b>
          <span>{t}</span>
        </div>
      ))}
    </div>

    <!-- Controls -->
    <div class="controls">
      <div class="search-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          id="search"
          class="search"
          type="search"
          placeholder="Search everything..."
          autocomplete="off"
        />
        <div class="search-results-panel" id="search-results" hidden></div>
      </div>
      <div class="chips" id="type-chips">
        <button class="chip" data-type="all" aria-pressed="true">All</button>
        {types.map((t) => (
          <button class="chip" data-type={t} aria-pressed="false">{t}</button>
        ))}
      </div>
    </div>

    <!-- Grid -->
    <div class="grid" id="grid">
      {entries.map((e, i) => {
        const searchText = (
          e.data.title + " " + e.data.tags.join(" ") + " " + e.data.type + " " + excerpt(e.body)
        ).toLowerCase();
        return (
          <article
            class={`card`}
            data-type={e.data.type}
            data-search={searchText}
            data-animate
            style={`animation-delay: ${Math.min(i * 0.05, 0.4)}s`}
          >
            {e.data.pinned && <span class="pin" />}
            <div class="meta">
              <span class="type">{e.data.type}</span>
              {(e.data.updated || e.data.created) && (
                <span class="date">
                  {(e.data.updated ?? e.data.created)!.toISOString().slice(0, 10)}
                </span>
              )}
            </div>
            <h3>
              <a href={`/${e.id}/`}>{e.data.title}</a>
              {e.data.url && (
                <a class="card-external" href={e.data.url} target="_blank" rel="noopener" title="Open link">&nearr;</a>
              )}
            </h3>
            {excerpt(e.body) && <p class="excerpt">{excerpt(e.body)}</p>}
            {e.data.tags.length > 0 && (
              <div class="tags">
                {e.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </article>
        );
      })}
    </div>
    <p class="empty" id="empty" hidden>No results found.</p>
  </div>
</Layout>

<script is:inline>
  // ---------- Cursor-following spotlight in hero ----------
  const hero = document.getElementById("hero");
  const spotlight = document.getElementById("hero-spotlight");
  hero?.addEventListener("pointermove", (e) => {
    const rect = hero.getBoundingClientRect();
    const x = ((e.clientX - rect.left) / rect.width) * 100;
    const y = ((e.clientY - rect.top) / rect.height) * 100;
    spotlight.style.background = `radial-gradient(circle at ${x}% ${y}%, rgba(129,140,248,0.16), transparent 55%)`;
  });

  // ---------- 3D tilt-on-hover for cards ----------
  function attachTilt(card) {
    card.addEventListener("pointermove", (e) => {
      const rect = card.getBoundingClientRect();
      const px = (e.clientX - rect.left) / rect.width - 0.5;
      const py = (e.clientY - rect.top) / rect.height - 0.5;
      card.style.transform = `perspective(700px) rotateX(${(-py * 6).toFixed(2)}deg) rotateY(${(px * 8).toFixed(2)}deg) translateZ(4px)`;
    });
    card.addEventListener("pointerleave", () => {
      card.style.transform = "";
    });
  }

  const search = document.getElementById("search");
  const grid = document.getElementById("grid");
  const empty = document.getElementById("empty");
  const chips = document.getElementById("type-chips");
  const resultsPanel = document.getElementById("search-results");
  const cards = Array.from(grid.querySelectorAll(".card"));
  cards.forEach(attachTilt);
  let activeType = "all";
  let query = "";

  function apply() {
    let shown = 0;
    for (const card of cards) {
      const matchType = activeType === "all" || card.dataset.type === activeType;
      const matchText = !query || card.dataset.search.includes(query);
      const show = matchType && matchText;
      card.hidden = !show;
      if (show) shown++;
    }
    empty.hidden = shown !== 0;
  }

  // ---------- Real fuzzy/full-text search via Pagefind ----------
  // Pagefind indexes each note's full body (not just the visible excerpt),
  // so this surfaces matches the simple substring filter above would miss.
  let pagefind = null;
  (async () => {
    try {
      pagefind = await import("/pagefind/pagefind.js");
      await pagefind.init();
    } catch {
      // No index yet (e.g. local `astro dev`, or nothing published yet) — the
      // basic substring filter above still works fine without this.
    }
  })();

  let searchDebounce;
  async function runPagefindSearch(q) {
    if (!pagefind || !q) {
      resultsPanel.hidden = true;
      resultsPanel.innerHTML = "";
      return;
    }
    const res = await pagefind.search(q);
    const items = await Promise.all(res.results.slice(0, 8).map((r) => r.data()));
    if (!items.length) {
      resultsPanel.innerHTML = `<p class="search-results-empty">No matches in full note content.</p>`;
      resultsPanel.hidden = false;
      return;
    }
    resultsPanel.innerHTML = items
      .map(
        (item) => `
        <a class="search-result" href="${item.url}">
          <span class="search-result-title">${item.meta?.title || item.url}</span>
          <span class="search-result-excerpt">${item.excerpt}</span>
        </a>`
      )
      .join("");
    resultsPanel.hidden = false;
  }

  search.addEventListener("input", (e) => {
    query = e.target.value.trim().toLowerCase();
    apply();
    clearTimeout(searchDebounce);
    searchDebounce = setTimeout(() => runPagefindSearch(query), 200);
  });

  document.addEventListener("click", (e) => {
    if (!e.target.closest(".search-wrap")) {
      resultsPanel.hidden = true;
    }
  });

  chips.addEventListener("click", (e) => {
    const btn = e.target.closest(".chip");
    if (!btn) return;
    activeType = btn.dataset.type;
    chips.querySelectorAll(".chip").forEach((c) =>
      c.setAttribute("aria-pressed", String(c === btn))
    );
    apply();
  });
</script>
