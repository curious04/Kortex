---
export const prerender = true;
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { WIKILINK_RE, wikilinkSlug, resolveWikilink } from "../lib/wikilinks.mjs";

const notes = await getCollection("notes", ({ data }) => data.public !== false);
const candidates = notes.map((n) => ({ id: n.id, slug: wikilinkSlug(n.data.title) }));

const nodes = notes.map((n) => ({ id: n.id, title: n.data.title, type: n.data.type }));

const edgeSet = new Set();
const edges = [];
for (const n of notes) {
  const matches = [...(n.body || "").matchAll(WIKILINK_RE)];
  for (const m of matches) {
    const target = resolveWikilink(m[1].trim(), candidates);
    if (!target || target.id === n.id) continue;
    const key = [n.id, target.id].sort().join("::");
    if (edgeSet.has(key)) continue;
    edgeSet.add(key);
    edges.push({ source: n.id, target: target.id });
  }
}
---

<Layout title="Knowledge graph">
  <div class="wrap graph-page">
    <div class="graph-heading-row">
      <div>
        <h1 class="animate-in">Knowledge graph</h1>
        <p class="graph-sub animate-in delay-1">
          {nodes.length} notes &middot; {edges.length} connections via <code>[[wiki-links]]</code>
        </p>
      </div>
      {nodes.length > 0 && (
        <div class="graph-toolbar animate-in delay-1">
          <button type="button" class="btn sm" id="graph-rotate-toggle" title="Toggle auto-rotate">⟳ Rotate</button>
          <button type="button" class="btn sm" id="graph-reset-view" title="Reset camera">⤢ Fit view</button>
        </div>
      )}
    </div>

    {nodes.length === 0 ? (
      <p class="empty">No notes yet. Add some, and link them with <code>[[Note Title]]</code> in the content to see them connect here.</p>
    ) : (
      <>
        <div class="graph-canvas-wrap animate-in delay-2">
          <div id="graph-3d" data-nodes={JSON.stringify(nodes)} data-edges={JSON.stringify(edges)}></div>
          <div class="graph-loading" id="graph-loading">Rendering 3D graph…</div>
        </div>
        <div class="graph-legend animate-in delay-3">
          <span class="legend-item"><i class="legend-dot" style="background:#6366f1"></i>note</span>
          <span class="legend-item"><i class="legend-dot" style="background:#6ee7b7"></i>link</span>
          <span class="legend-item"><i class="legend-dot" style="background:#c084fc"></i>idea</span>
          <span class="legend-item"><i class="legend-dot" style="background:#fbbf24"></i>task</span>
          <span class="legend-item"><i class="legend-dot" style="background:#f472b6"></i>routine</span>
          <span class="legend-item"><i class="legend-dot" style="background:#38bdf8"></i>reference</span>
          <span class="legend-item"><i class="legend-dot" style="background:#a78bfa"></i>doc</span>
          <span class="legend-hint">drag to orbit · scroll to zoom · click a node to open it</span>
        </div>
      </>
    )}
  </div>
</Layout>

<script>
  import ForceGraph3D from "3d-force-graph";

  const NODE_COLORS: Record<string, string> = {
    note: "#6366f1",
    link: "#6ee7b7",
    idea: "#c084fc",
    task: "#fbbf24",
    routine: "#f472b6",
    reference: "#38bdf8",
    doc: "#a78bfa",
  };

  function escapeHtml(str: string) {
    return String(str).replace(/[&<>"']/g, (c) => (
      { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c] || c
    ));
  }

  const container = document.getElementById("graph-3d");
  const loading = document.getElementById("graph-loading");
  const rotateBtn = document.getElementById("graph-rotate-toggle");
  const resetBtn = document.getElementById("graph-reset-view");

  if (container) {
    const nodes = JSON.parse(container.dataset.nodes || "[]");
    const edges = JSON.parse(container.dataset.edges || "[]");

    // size nodes by how connected they are — hubs stand out more
    const degree = new Map<string, number>();
    for (const e of edges) {
      degree.set(e.source, (degree.get(e.source) || 0) + 1);
      degree.set(e.target, (degree.get(e.target) || 0) + 1);
    }
    nodes.forEach((n: any) => { n.val = 1 + (degree.get(n.id) || 0) * 0.6; });

    const wrap = container.closest(".graph-canvas-wrap") as HTMLElement | null;

    const Graph = new ForceGraph3D(container)
      .graphData({ nodes, links: edges })
      .backgroundColor("#0a0a0c")
      .showNavInfo(false)
      .controlType("orbit")
      .nodeLabel((n: any) => `<div class="graph-tip"><strong>${escapeHtml(n.title)}</strong><span>${escapeHtml(n.type)}</span></div>`)
      .nodeVal("val")
      .nodeRelSize(4)
      .nodeOpacity(0.92)
      .nodeResolution(16)
      .nodeColor((n: any) => NODE_COLORS[n.type] || NODE_COLORS.note)
      .linkColor(() => "rgba(160,160,200,0.35)")
      .linkOpacity(0.4)
      .linkWidth(0.6)
      .linkDirectionalParticles(2)
      .linkDirectionalParticleWidth(1.4)
      .linkDirectionalParticleSpeed(0.006)
      .linkDirectionalParticleColor(() => "#818cf8")
      .onNodeClick((n: any) => { window.location.href = `/${n.id}/`; })
      .onNodeHover((n: any) => { container.style.cursor = n ? "pointer" : "default"; });

    const controls: any = Graph.controls();
    controls.autoRotate = true;
    controls.autoRotateSpeed = 0.6;
    rotateBtn?.classList.add("active");

    container.addEventListener("pointerdown", () => {
      if (controls.autoRotate) {
        controls.autoRotate = false;
        rotateBtn?.classList.remove("active");
      }
    }, { once: true });

    function resize() {
      const w = (wrap || container).clientWidth;
      Graph.width(w);
      Graph.height(Math.min(640, Math.max(420, Math.round(window.innerHeight * 0.62))));
    }
    resize();
    window.addEventListener("resize", resize);

    setTimeout(() => Graph.zoomToFit(800, 60), 300);
    loading?.remove();

    rotateBtn?.addEventListener("click", () => {
      controls.autoRotate = !controls.autoRotate;
      rotateBtn.classList.toggle("active", controls.autoRotate);
    });
    resetBtn?.addEventListener("click", () => Graph.zoomToFit(800, 60));
  } else {
    loading?.remove();
  }
</script>
