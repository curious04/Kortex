---
export const prerender = true;
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { WIKILINK_RE, wikilinkSlug, resolveWikilink } from "../lib/wikilinks.mjs";

const notes = await getCollection("notes", ({ data }) => data.public !== false);
const candidates = notes.map((n) => ({ id: n.id, slug: wikilinkSlug(n.data.title) }));

const nodes = notes.map((n) => ({ id: n.id, title: n.data.title, type: n.data.type }));

const edgeSet = new Set();
const edges = [];
for (const n of notes) {
  const matches = [...(n.body || "").matchAll(WIKILINK_RE)];
  for (const m of matches) {
    const target = resolveWikilink(m[1].trim(), candidates);
    if (!target || target.id === n.id) continue;
    const key = [n.id, target.id].sort().join("::");
    if (edgeSet.has(key)) continue;
    edgeSet.add(key);
    edges.push({ source: n.id, target: target.id });
  }
}
---

<Layout title="Knowledge graph">
  <div class="wrap graph-page">
    <div class="graph-heading-row">
      <div>
        <h1 class="animate-in">Knowledge graph</h1>
        <p class="graph-sub animate-in delay-1">
          {nodes.length} notes &middot; {edges.length} connections via <code>[[wiki-links]]</code>
        </p>
      </div>
      {nodes.length > 0 && (
        <div class="graph-toolbar animate-in delay-1">
          <div class="graph-search-wrap">
            <input type="text" id="graph-search" class="graph-search" placeholder="🔍 Find a note…" autocomplete="off" />
            <div class="graph-search-results" id="graph-search-results" hidden></div>
          </div>
          <button type="button" class="btn sm" id="graph-rotate-toggle" title="Toggle auto-rotate">⟳ Rotate</button>
          <button type="button" class="btn sm" id="graph-reset-view" title="Reset camera">⤢ Fit view</button>
          <button type="button" class="btn sm" id="graph-link-toggle" title="Manually connect two notes" hidden>🔗 Link nodes</button>
        </div>
      )}
    </div>
    <p class="graph-link-hint" id="graph-link-hint" hidden>
      Link mode: click a note, then click another to connect them &middot; click the same note twice to cancel.
    </p>

    {nodes.length === 0 ? (
      <p class="empty">No notes yet. Add some, and link them with <code>[[Note Title]]</code> in the content to see them connect here.</p>
    ) : (
      <>
        <div class="graph-canvas-wrap animate-in delay-2">
          <div id="graph-3d" data-nodes={JSON.stringify(nodes)} data-edges={JSON.stringify(edges)}></div>
          <div class="graph-loading" id="graph-loading">Rendering 3D graph…</div>
          <div class="graph-node-card" id="graph-node-card" hidden>
            <div class="gnc-head">
              <span class="gnc-type" id="gnc-type"></span>
              <button type="button" class="gnc-close" id="gnc-close" aria-label="Close preview">✕</button>
            </div>
            <div class="gnc-title" id="gnc-title"></div>
            <button type="button" class="btn sm primary" id="gnc-open">Open note →</button>
          </div>
        </div>
        <div class="graph-legend animate-in delay-3">
          <span class="legend-item"><i class="legend-dot" style="background:#6366f1"></i>note</span>
          <span class="legend-item"><i class="legend-dot" style="background:#6ee7b7"></i>link</span>
          <span class="legend-item"><i class="legend-dot" style="background:#c084fc"></i>idea</span>
          <span class="legend-item"><i class="legend-dot" style="background:#fbbf24"></i>task</span>
          <span class="legend-item"><i class="legend-dot" style="background:#f472b6"></i>routine</span>
          <span class="legend-item"><i class="legend-dot" style="background:#38bdf8"></i>reference</span>
          <span class="legend-item"><i class="legend-dot" style="background:#a78bfa"></i>doc</span>
          <span class="legend-hint">tap/click a note to preview it, then again to open it · drag to orbit · scroll to zoom</span>
        </div>
      </>
    )}
  </div>
</Layout>

<script>
  import ForceGraph3D from "3d-force-graph";

  const NODE_COLORS: Record<string, string> = {
    note: "#6366f1",
    link: "#6ee7b7",
    idea: "#c084fc",
    task: "#fbbf24",
    routine: "#f472b6",
    reference: "#38bdf8",
    doc: "#a78bfa",
  };

  function escapeHtml(str: string) {
    return String(str).replace(/[&<>"']/g, (c) => (
      { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c] || c
    ));
  }

  const container = document.getElementById("graph-3d");
  const loading = document.getElementById("graph-loading");
  const rotateBtn = document.getElementById("graph-rotate-toggle");
  const resetBtn = document.getElementById("graph-reset-view");
  const linkModeBtn = document.getElementById("graph-link-toggle");
  const linkHint = document.getElementById("graph-link-hint");
  const searchInput = document.getElementById("graph-search") as HTMLInputElement | null;
  const searchResults = document.getElementById("graph-search-results");
  const nodeCard = document.getElementById("graph-node-card");
  const nodeCardType = document.getElementById("gnc-type");
  const nodeCardTitle = document.getElementById("gnc-title");
  const nodeCardOpen = document.getElementById("gnc-open");
  const nodeCardClose = document.getElementById("gnc-close");

  if (container) {
    const nodes = JSON.parse(container.dataset.nodes || "[]");
    const edges = JSON.parse(container.dataset.edges || "[]");
    const edgeKeys = new Set(edges.map((e: any) => [e.source, e.target].sort().join("::")));

    // size nodes by how connected they are — hubs stand out more
    const degree = new Map<string, number>();
    for (const e of edges) {
      degree.set(e.source, (degree.get(e.source) || 0) + 1);
      degree.set(e.target, (degree.get(e.target) || 0) + 1);
    }
    nodes.forEach((n: any) => { n.val = 1 + (degree.get(n.id) || 0) * 0.6; });

    const wrap = container.closest(".graph-canvas-wrap") as HTMLElement | null;

    let linkMode = false;
    let selectedSourceId: string | null = null;
    let previewedId: string | null = null;
    let linking = false;

    // First click on a note previews its title (fixes: on mobile there's no hover to
    // reveal the title before navigating away; on desktop with many nodes, a persistent
    // preview beats having to hover each one to find the right note). Clicking the SAME
    // note again (or the "Open note" button) actually navigates to it.
    function showNodeCard(n: any) {
      previewedId = n.id;
      if (nodeCardType) nodeCardType.textContent = n.type;
      if (nodeCardTitle) nodeCardTitle.textContent = n.title;
      if (nodeCard) nodeCard.hidden = false;
      Graph.refresh();
    }

    function hideNodeCard() {
      previewedId = null;
      if (nodeCard) nodeCard.hidden = true;
      Graph.refresh();
    }

    function focusOnNode(n: any) {
      const x = n.x || 0.01;
      const y = n.y || 0.01;
      const z = n.z || 0.01;
      const distRatio = 1 + 90 / Math.hypot(x, y, z);
      Graph.cameraPosition({ x: x * distRatio, y: y * distRatio, z: z * distRatio }, n, 1200);
      controls.autoRotate = false;
      rotateBtn?.classList.remove("active");
      if (!linkMode) showNodeCard(n);
    }

    async function handleNodeClick(n: any) {
      if (!linkMode) {
        if (previewedId === n.id) {
          window.location.href = `/${n.id}/`;
        } else {
          showNodeCard(n);
        }
        return;
      }
      if (linking) return;
      if (!selectedSourceId) {
        selectedSourceId = n.id;
        Graph.refresh();
        (window as any).toast?.(`Selected "${n.title}" — click another note to link it to.`, "info");
        return;
      }
      if (selectedSourceId === n.id) {
        selectedSourceId = null;
        Graph.refresh();
        return;
      }
      const sourceId = selectedSourceId;
      const sourceNode = nodes.find((x: any) => x.id === sourceId);
      selectedSourceId = null;
      Graph.refresh();

      const key = [sourceId, n.id].sort().join("::");
      if (edgeKeys.has(key)) {
        (window as any).toast?.("Already linked", "info");
        return;
      }

      linking = true;
      try {
        const res = await fetch("/api/content/link", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ sourceId, targetTitle: n.title }),
        });
        const result = await res.json();
        if (!res.ok || result.error) throw new Error(result.error || "Linking failed");

        edgeKeys.add(key);
        if (result.alreadyLinked) {
          (window as any).toast?.("Already linked", "info");
          return;
        }

        edges.push({ source: sourceId, target: n.id });
        Graph.graphData({ nodes, links: edges });

        (window as any).toast?.(`Linked "${sourceNode?.title || sourceId}" → "${n.title}" — deploying...`, "success");
        (window as any).kortexAwaitDeploy?.(result.commitSha, { onReady: () => location.reload() });
      } catch (err: any) {
        (window as any).toast?.(err.message || "Linking failed", "error");
      } finally {
        linking = false;
      }
    }

    const Graph = new ForceGraph3D(container, { controlType: "orbit" })
      .graphData({ nodes, links: edges })
      .backgroundColor("#0a0a0c")
      .showNavInfo(false)
      .nodeLabel((n: any) => `<div class="graph-tip"><strong>${escapeHtml(n.title)}</strong><span>${escapeHtml(n.type)}</span></div>`)
      .nodeVal("val")
      .nodeRelSize(4)
      .nodeOpacity(0.92)
      .nodeResolution(16)
      .nodeColor((n: any) => {
        if (n.id === selectedSourceId) return "#ffffff";
        if (n.id === previewedId) return "#facc15";
        return NODE_COLORS[n.type] || NODE_COLORS.note;
      })
      .linkColor(() => "rgba(160,160,200,0.35)")
      .linkOpacity(0.4)
      .linkWidth(0.6)
      .linkDirectionalParticles(2)
      .linkDirectionalParticleWidth(1.4)
      .linkDirectionalParticleSpeed(0.006)
      .linkDirectionalParticleColor(() => "#818cf8")
      .enableNodeDrag(false)
      .onNodeClick((n: any) => handleNodeClick(n))
      .onNodeHover((n: any) => { container.style.cursor = n ? "pointer" : linkMode ? "crosshair" : "default"; })
      .onBackgroundClick(() => { if (!linkMode) hideNodeCard(); });

    const controls: any = Graph.controls();
    controls.autoRotate = true;
    controls.autoRotateSpeed = 0.6;
    rotateBtn?.classList.add("active");

    container.addEventListener("pointerdown", () => {
      if (controls.autoRotate) {
        controls.autoRotate = false;
        rotateBtn?.classList.remove("active");
      }
    }, { once: true });

    function resize() {
      const w = (wrap || container).clientWidth;
      Graph.width(w);
      Graph.height(Math.min(640, Math.max(420, Math.round(window.innerHeight * 0.62))));
    }
    resize();
    window.addEventListener("resize", resize);

    setTimeout(() => Graph.zoomToFit(800, 60), 300);
    loading?.remove();

    rotateBtn?.addEventListener("click", () => {
      controls.autoRotate = !controls.autoRotate;
      rotateBtn.classList.toggle("active", controls.autoRotate);
    });
    resetBtn?.addEventListener("click", () => Graph.zoomToFit(800, 60));

    // ---- Owner-only manual linking: read-only for everyone else ----
    function applyOwnerUI(isOwner: boolean) {
      if (linkModeBtn) linkModeBtn.hidden = !isOwner;
    }
    if (typeof (window as any).KORTEX_IS_OWNER !== "undefined") applyOwnerUI((window as any).KORTEX_IS_OWNER);
    document.addEventListener("kortex:auth", (e: any) => applyOwnerUI(e.detail?.isOwner));

    linkModeBtn?.addEventListener("click", () => {
      linkMode = !linkMode;
      selectedSourceId = null;
      hideNodeCard();
      linkModeBtn.classList.toggle("active", linkMode);
      if (linkHint) linkHint.hidden = !linkMode;
      container.style.cursor = linkMode ? "crosshair" : "default";
    });

    // ---- "Find a note" search: fuzzy-match by title, fly the camera to it ----
    // Solves: with many nodes it's impractical to hover each one to find a specific
    // note — type its title instead and jump straight to it.
    function fuzzyScore(query: string, text: string) {
      query = query.toLowerCase();
      text = text.toLowerCase();
      if (!query) return 0;
      if (text.includes(query)) return 100 - text.indexOf(query);
      let qi = 0;
      for (let i = 0; i < text.length && qi < query.length; i++) {
        if (text[i] === query[qi]) qi++;
      }
      return qi === query.length ? 10 : -1;
    }

    function renderSearchResults(query: string) {
      if (!searchResults) return;
      const matches = nodes
        .map((n: any) => ({ ...n, score: fuzzyScore(query, n.title) }))
        .filter((n: any) => n.score > 0)
        .sort((a: any, b: any) => b.score - a.score)
        .slice(0, 8);

      if (!matches.length) {
        searchResults.innerHTML = `<div class="graph-search-empty">No matching notes</div>`;
        searchResults.hidden = false;
        return;
      }
      searchResults.innerHTML = matches
        .map(
          (n: any) =>
            `<div class="graph-search-item" data-id="${n.id}"><span class="gsi-title">${escapeHtml(n.title)}</span><span class="gsi-type">${escapeHtml(n.type)}</span></div>`,
        )
        .join("");
      searchResults.hidden = false;
    }

    function selectSearchResult(id: string) {
      const n = nodes.find((x: any) => x.id === id);
      if (n) {
        focusOnNode(n);
        if (searchInput) searchInput.value = n.title;
      }
      if (searchResults) searchResults.hidden = true;
    }

    searchInput?.addEventListener("input", () => {
      const q = searchInput.value.trim();
      if (!q) {
        if (searchResults) searchResults.hidden = true;
        return;
      }
      renderSearchResults(q);
    });

    searchInput?.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        const first = searchResults?.querySelector(".graph-search-item") as HTMLElement | null;
        if (first?.dataset.id) selectSearchResult(first.dataset.id);
      } else if (e.key === "Escape") {
        if (searchResults) searchResults.hidden = true;
      }
    });

    searchResults?.addEventListener("mousedown", (e: any) => {
      const item = e.target.closest(".graph-search-item");
      if (item?.dataset.id) {
        e.preventDefault();
        selectSearchResult(item.dataset.id);
      }
    });

    searchInput?.addEventListener("blur", () => {
      setTimeout(() => {
        if (searchResults) searchResults.hidden = true;
      }, 150);
    });

    // ---- Node preview card actions ----
    nodeCardOpen?.addEventListener("click", () => {
      if (previewedId) window.location.href = `/${previewedId}/`;
    });
    nodeCardClose?.addEventListener("click", hideNodeCard);
  } else {
    loading?.remove();
  }
</script>
